# ============================================================================
# SPKLU Gateway — konfigurasi. Salin ke .env lalu sesuaikan.
#   cp .env.example .env
# JANGAN commit .env (berisi DEVICE_KEY rahasia).
# ============================================================================

# URL server SPKLU (tempat backend berjalan).
#   - Uji lokal (backend di PC ini)      : http://localhost:3000
#   - Produksi (server cloud Biznet)     : http://202.74.75.231
SERVER_URL=http://202.74.75.231

# Token rahasia mesin — HARUS sama dengan kolom devices.device_key di database.
DEVICE_KEY=CHANGE_ME_DEVICE_KEY

# Port serial tempat ESP32 tersambung.
#   - Windows : COM3, COM4, COM5, ...   (jalankan: npm run list)
#   - Linux   : /dev/ttyUSB0, /dev/ttyACM0
SERIAL_PORT=COM5

# Baud rate firmware (default 115200).
BAUD=115200

# Set 1 untuk menampilkan semua lalu-lintas serial di log (debug).
VERBOSE=0
