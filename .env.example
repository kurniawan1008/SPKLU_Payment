# ============================================================================
# SPKLU · Template Environment
# Salin ke .env lalu sesuaikan:  cp .env.example .env
# JANGAN commit file .env (berisi rahasia).
# ============================================================================

# ===== SERVER =====
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ===== DATABASE (MySQL) =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=spklu
DB_PASSWORD=ganti_dengan_password_kuat
DB_NAME=spklu_db
DB_POOL=10

# ===== KEAMANAN =====
# WAJIB diganti dengan string acak panjang & unik.
# Buat cepat:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti_dengan_secret_acak_panjang
JWT_EXPIRES_IN=8h

# ===== CORS =====
# Domain produksi yang boleh mengakses API. Pisahkan dengan koma.
# Karena frontend disajikan dari server yang sama, isi dengan domain Anda.
ALLOWED_ORIGINS=https://spklu.contoh.com

# ===== TARIF =====
PRICE_PER_KWH=2440
